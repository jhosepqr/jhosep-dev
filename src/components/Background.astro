---
import DotField from './DotField.jsx';
---

<div class="background-anim" style="position: fixed; inset: 0; width: 100vw; height: 100vh; overflow: hidden; z-index: 0;">
  <div class="bg-blur bg-blur-1"></div>
  <div class="bg-blur bg-blur-2"></div>
  <div style="position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none;">
    <DotField
      client:load
      dotRadius={2.2}
      dotSpacing={16}
      bulgeStrength={80}
      glowRadius={220}
      sparkle={true}
      waveAmplitude={3}
      gradientFrom="rgba(56, 189, 248, 0.55)"
      gradientTo="rgba(99, 102, 241, 0.3)"
      glowColor="rgba(56, 189, 248, 0.25)"
    />
  </div>
</div>

