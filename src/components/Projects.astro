---
---
<section id="projects-view" class="section-view is-hidden">
            
            <!-- View Head (Breadcrumbs + Return) -->
            <div class="projects-head">
              <nav class="breadcrumbs" aria-label="Navegación secundaria">
                <a onclick="navigateTo('home-view')">inicio</a>
                <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                <strong>proyectos</strong>
              </nav>
              <button class="btn-back" onclick="navigateTo('home-view')" aria-label="Volver al inicio">
                <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
                <span>Volver</span>
              </button>
            </div>

            <!-- View Body -->
            <div class="projects-body">
              
              <!-- Desktop Grid (Hidden on Mobile) -->
              <div class="projects-grid">
                
                <!-- Project 1: Featured (nikao.tech) -->
                <article class="project-card featured">
                  <div class="project-card-top">
                    <span class="project-kicker">Web Principal / Marca</span>
                    <h2 class="project-title">nikao.tech</h2>
                    <p class="project-desc">
                      Hub digital y marca matriz. Desarrollo de software premium y soluciones de ingeniería de alto impacto.
                    </p>
                  </div>
                  <div class="featured-visual">
                    <img src="logo.webp" alt="JR - Jhosep Quiroz" style="width: 80px; height: 80px; object-fit: contain; filter: drop-shadow(0 0 12px rgba(99,102,241,0.3));" />
                  </div>
                  <a class="project-link" href="https://nikao.tech" target="_self" rel="noopener">
                    <span>Visitar sitio</span>
                    <svg viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                  </a>
                </article>

                <!-- 2x2 Grid for the other 4 projects -->
                <div class="projects-col-right">
                  <!-- Project 2: fgnewgen.org -->
                  <article class="project-card">
                    <div class="project-card-top">
                      <span class="project-kicker">Web Corporativa</span>
                      <h2 class="project-title">fgnewgen.org</h2>
                      <p class="project-desc">Portal corporativo global desarrollado para una firma multinacional de suplementos y nutrición.</p>
                    </div>
                    <a class="project-link" href="https://fgnewgen.org" target="_self" rel="noopener">
                      <span>Visitar</span>
                      <svg viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                    </a>
                  </article>

                  <!-- Project 3: bo.fgnewgen.org -->
                  <article class="project-card">
                    <div class="project-card-top">
                      <span class="project-kicker">Backoffice ERP</span>
                      <h2 class="project-title">bo.fgnewgen.org</h2>
                      <p class="project-desc">Sistema de gestión interna y control de datos para red multinivel de suplementos.</p>
                    </div>
                    <a class="project-link" href="https://bo.fgnewgen.org" target="_self" rel="noopener">
                      <span>Acceder</span>
                      <svg viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                    </a>
                  </article>

                  <!-- Project 4: nikao.com.ar -->
                  <article class="project-card">
                    <div class="project-card-top">
                      <span class="project-kicker">POS Cloud</span>
                      <h2 class="project-title">nikao pos</h2>
                      <p class="project-desc">Sistema POS Cloud integral a medida para la gestión de locales gastronómicos.</p>
                    </div>
                    <a class="project-link" href="https://nikao.com.ar" target="_self" rel="noopener">
                      <span>Visitar</span>
                      <svg viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                    </a>
                  </article>

                  <!-- Project 5: Facturador Argentino -->
                  <article class="project-card">
                    <div class="project-card-top">                      
                      <span class="project-kicker">Microservicio API</span>
                      <h2 class="project-title">facturador arg</h2>
                      <p class="project-desc">Microservicio RESTful para facturación electrónica argentina automatizada y sincronización con AFIP.</p>
                    </div>
                    <a class="project-link" href="https://facturadorarg-jhosep.web.app" target="_self" rel="noopener">
                      <span>Visitar</span>
                      <svg viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                    </a>
                  </article>
                </div>

              </div>

              <!-- Mobile Swiping Carousel (Visible on mobile, no vertical scroll) -->
              <div class="mobile-carousel-container">
                <div class="mobile-scroll-row">
                  
                  <!-- Card 1: nikao.tech -->
                  <div class="mobile-carousel-card">
                    <div class="project-card-top">
                      <span class="project-kicker">Web Principal / Marca</span>
                      <h2 class="project-title">nikao.tech</h2>
                      <p class="project-desc">Hub digital y marca matriz. Desarrollo de software premium y soluciones de ingeniería de alto impacto.</p>
                    </div>
                    <a class="project-link" href="https://nikao.tech" target="_self" rel="noopener">
                      <span>Visitar sitio</span>
                      <svg viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                    </a>
                  </div>

                  <!-- Card 2: fgnewgen.org -->
                  <div class="mobile-carousel-card">
                    <div class="project-card-top">
                      <span class="project-kicker">Web Corporativa</span>
                      <h2 class="project-title">fgnewgen.org</h2>
                      <p class="project-desc">Portal corporativo global desarrollado para una firma multinacional de suplementos y nutrición.</p>
                    </div>
                    <a class="project-link" href="https://fgnewgen.org" target="_self" rel="noopener">
                      <span>Visitar</span>
                      <svg viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                    </a>
                  </div>

                  <!-- Card 3: bo.fgnewgen.org -->
                  <div class="mobile-carousel-card">
                    <div class="project-card-top">
                      <span class="project-kicker">Backoffice ERP</span>
                      <h2 class="project-title">bo.fgnewgen.org</h2>
                      <p class="project-desc">Sistema de gestión interna y control de datos para red multinivel de suplementos.</p>
                    </div>
                    <a class="project-link" href="https://bo.fgnewgen.org" target="_self" rel="noopener">
                      <span>Acceder</span>
                      <svg viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                    </a>
                  </div>

                  <!-- Card 4: nikao.com.ar -->
                  <div class="mobile-carousel-card">
                    <div class="project-card-top">
                      <span class="project-kicker">POS Cloud</span>
                      <h2 class="project-title">nikao pos</h2>
                      <p class="project-desc">Sistema POS Cloud integral a medida para la gestión de locales gastronómicos.</p>
                    </div>
                    <a class="project-link" href="https://nikao.com.ar" target="_self" rel="noopener">
                      <span>Visitar</span>
                      <svg viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                    </a>
                  </div>

                  <!-- Card 5: Facturador Argentino -->
                  <div class="mobile-carousel-card">
                    <div class="project-card-top">
                      <span class="project-kicker">Microservicio API</span>
                      <h2 class="project-title">facturador arg</h2>
                      <p class="project-desc">Microservicio RESTful para facturación electrónica argentina automatizada y sincronización con AFIP.</p>
                    </div>
                    <a class="project-link" href="https://facturadorarg-jhosep.web.app" target="_self" rel="noopener">
                      <span>Visitar</span>
                      <svg viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                    </a>
                  </div>

                </div>
                <!-- Floating hint indicator -->
                <div class="scroll-hint">
                  <span>Desliza</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <polyline points="19 12 12 19 5 12"></polyline>
                  </svg>
                </div>
              </div>

            </div>
          </section>
