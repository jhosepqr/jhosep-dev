---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<title>{title}</title>
<meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content="Tarjeta de presentación virtual de Jhosep Quiroz, Dev Full Stack, y nikao.tech. Stack tecnológico, proyectos destacados y contacto." />
    
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Devicon - Technology Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>

      :root {
        /* taste-skill Dials: DESIGN_VARIANCE: 6 | MOTION_INTENSITY: 5 | VISUAL_DENSITY: 5 */
        
        /* OKLCH-based theme palette (restrained slate with Electric Blue accent) */
        --bg-dark: oklch(12% 0.015 240);
        --bg-dark-soft: oklch(15% 0.02 242);
        --panel-bg: rgba(15, 23, 42, 0.6);
        --panel-bg-hover: rgba(22, 32, 57, 0.75);
        --panel-border: rgba(255, 255, 255, 0.07);
        --panel-border-glow: rgba(99, 102, 241, 0.25);
        
        /* Text colors */
        --text-primary: oklch(98% 0.005 240);
        --text-secondary: oklch(84% 0.015 240);
        --text-muted: oklch(62% 0.02 240);
        
        /* Electric Blue Brand Accent */
        --accent-blue: oklch(68% 0.17 250);
        --accent-blue-dim: oklch(68% 0.17 250 / 0.15);
        
        /* Gradients */
        --brand-grad: linear-gradient(135deg, oklch(80% 0.1 210) 0%, var(--accent-blue) 100%);
        
        /* Layout vars */
        --shadow-premium: 0 24px 80px rgba(0, 0, 0, 0.5);
        --radius-lg: 16px;
        --radius-md: 10px;
        --radius-pill: 50px;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html, body {
        width: 100%;
        height: 100dvh;
        overflow: hidden;
        background-color: var(--bg-dark);
      }

      body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--text-primary);
        padding: clamp(12px, 3vw, 24px);
        display: grid;
        place-items: center;
        position: relative;
      }

      /* Moving background glow nodes */
      .bg-blur {
        position: fixed;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
        filter: blur(130px);
        opacity: 0.12;
      }

      .bg-blur-1 {
        top: -100px;
        left: -100px;
        background: var(--accent-blue);
        animation: float-slow 30s infinite ease-in-out;
      }

      .bg-blur-2 {
        bottom: -150px;
        right: -100px;
        background: oklch(60% 0.15 280);
        animation: float-slow 25s infinite ease-in-out alternate;
      }

      @keyframes float-slow {
        0% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(40px, -40px) scale(1.08); }
        100% { transform: translate(0, 0) scale(1); }
      }

      /* Base Layout Container - Locked to fit single screen */
      .shell {
        width: 100%;
        max-width: 900px;
        height: 100%;
        position: relative;
        z-index: 1;
        display: flex;
        align-items: stretch;
        perspective: 1200px;
      }

      @media (min-width: 769px) {
        .shell {
          height: 520px; /* Locked desktop card height */
        }
      }

      @media (max-width: 768px) {
        .shell {
          height: 100%;
          max-height: calc(100dvh - 24px); /* Constrained mobile view height */
        }
      }

      /* Card Container (Strictly scroll-free) */
      .card-container {
        width: 100%;
        height: 100%;
        background: linear-gradient(180deg, rgba(20, 30, 48, 0.7) 0%, rgba(10, 16, 26, 0.8) 100%);
        border: 1px solid var(--panel-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-premium);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transform-style: preserve-3d;
        will-change: transform;
        transition: transform 0.15s ease-out, box-shadow 0.3s ease;
      }

      .card-container.is-tilting {
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.55), 0 0 40px rgba(99, 102, 241, 0.08);
      }

      /* View Transitions support */
      @supports (view-transition-name: card) {
        .card-container {
          view-transition-name: card;
        }
      }

      /* Header top bar */
      .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 24px;
        border-bottom: 1px solid var(--panel-border);
        background: rgba(255, 255, 255, 0.005);
        flex-shrink: 0;
        width: 100%;
      }

      .brand-wrapper {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .brand-logo {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-md);
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.2);
        overflow: hidden;
      }

      .brand-logo:hover {
        transform: rotate(5deg) scale(1.08);
      }

      .brand-logo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: inherit;
      }

      .brand-info h3 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: 0.2px;
      }

      .brand-info span {
        font-size: 0.76rem;
        color: var(--text-muted);
        font-weight: 500;
      }

      .header-badge {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        color: var(--accent-blue);
        background: var(--accent-blue-dim);
        padding: 5px 12px;
        border-radius: var(--radius-pill);
        border: 1px solid rgba(99, 102, 241, 0.2);
        display: flex;
        align-items: center;
        gap: 5px;
        flex-shrink: 0;
      }

      .header-badge::before {
        content: '';
        display: block;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background-color: var(--accent-blue);
        box-shadow: 0 0 6px var(--accent-blue);
      }

      /* Body Wrapper - Fills space and prevents overflow */
      .card-body-wrapper {
        flex-grow: 1;
        overflow: hidden;
        position: relative;
        height: 100%;
        width: 100%;
      }

      /* View section defaults */
      .section-view {
        width: 100%;
        height: 100%;
        position: absolute;
        inset: 0;
        display: none;
        overflow: hidden;
      }

      .section-view.is-visible {
        display: flex;
        flex-direction: column;
      }

      /* Home Grid Layout */
      .grid-layout {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 24px;
        padding: 24px;
        height: 100%;
        width: 100%;
        align-items: stretch;
        overflow: hidden;
      }

      /* Left Panel: Profile & Contact info */
      .identity-panel {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        gap: 20px;
        overflow: hidden;
      }

      .intro-block {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .identity-eyebrow {
        align-self: flex-start;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--accent-blue);
        background: var(--accent-blue-dim);
        padding: 4px 10px;
        border-radius: var(--radius-pill);
        border: 1px solid rgba(99, 102, 241, 0.15);
      }

      .intro-block h1 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: clamp(2rem, 4vw, 2.7rem);
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -0.5px;
        background: var(--brand-grad);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .intro-desc {
        color: var(--text-secondary);
        font-size: 0.92rem;
        line-height: 1.5;
        font-weight: 300;
      }

      .intro-desc strong {
        font-weight: 600;
        color: var(--text-primary);
        border-bottom: 1.5px solid rgba(99, 102, 241, 0.3);
      }

      .highlight-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 2px;
      }

      .highlight-pill {
        display: flex;
        align-items: center;
        gap: 5px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 5px 10px;
        border-radius: var(--radius-pill);
        font-size: 0.78rem;
        font-weight: 600;
        transition: all 0.2s ease;
      }

      .highlight-pill svg {
        width: 12px;
        height: 12px;
      }

      .highlight-pill.node:hover {
        background: rgba(131, 205, 41, 0.08);
        border-color: rgba(131, 205, 41, 0.3);
        color: #83cd29;
      }

      .highlight-pill.rails:hover {
        background: rgba(204, 0, 0, 0.08);
        border-color: rgba(204, 0, 0, 0.3);
        color: #cc0000;
      }

      .highlight-pill.python:hover {
        background: rgba(55, 115, 166, 0.08);
        border-color: rgba(55, 115, 166, 0.3);
        color: #3773a6;
      }

      /* Contact Block */
      .contact-block {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: auto;
      }

      .email-interactive {
        display: flex;
        align-items: center;
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid var(--panel-border);
        border-radius: var(--radius-md);
        padding: 4px 4px 4px 10px;
        justify-content: space-between;
        transition: all 0.25s ease;
      }

      .email-interactive:hover {
        border-color: rgba(99, 102, 241, 0.3);
        background: rgba(15, 23, 42, 0.65);
      }

      .email-text {
        font-size: 0.82rem;
        color: var(--text-secondary);
        font-weight: 500;
      }

      .email-actions {
        display: flex;
        gap: 4px;
      }

      .btn-icon {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        width: 30px;
        height: 30px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--text-secondary);
        transition: all 0.2s ease;
        position: relative;
      }

      .btn-icon:hover {
        background: rgba(255, 255, 255, 0.08);
        color: var(--text-primary);
        transform: translateY(-1px);
      }

      .btn-icon::after {
        content: 'Copiado';
        position: absolute;
        bottom: 120%;
        left: 50%;
        transform: translateX(-50%) translateY(4px);
        background: var(--accent-blue);
        color: var(--bg-dark);
        font-size: 0.65rem;
        font-weight: 700;
        padding: 3px 6px;
        border-radius: 3px;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: all 0.2s ease;
      }

      .btn-icon.copied::after {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
      }

      /* Subtle Projects navigation trigger */
      .subtle-projects-link {
        align-self: flex-start;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.7rem;
        color: var(--text-muted);
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.25s ease;
        opacity: 0.6;
        text-decoration: none;
      }

      .subtle-projects-link:hover {
        opacity: 1;
        color: var(--accent-blue);
        letter-spacing: 1.6px;
      }

      .subtle-projects-link svg {
        width: 10px;
        height: 10px;
        transition: transform 0.2s ease;
      }

      .subtle-projects-link:hover svg {
        transform: translateX(3px);
      }

      /* Right Panel: Stacks (Desktop view shows both) */
      .stacks-panel {
        display: flex;
        flex-direction: column;
        gap: 16px;
        overflow: hidden;
        height: 100%;
        justify-content: center;
      }

      .stack-box {
        background: var(--panel-bg);
        border: 1px solid var(--panel-border);
        border-radius: var(--radius-lg);
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: all 0.25s ease;
      }

      .stack-box:hover {
        background: var(--panel-bg-hover);
        border-color: rgba(255, 255, 255, 0.1);
      }

      .stack-box h2 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.88rem;
        font-weight: 600;
        letter-spacing: 0.2px;
        color: var(--text-primary);
      }

      .grid-icons {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 8px;
      }

      /* Tech Icon styling */
      .icon-card {
        aspect-ratio: 1;
        background: rgba(255, 255, 255, 0.015);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        position: relative;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .icon-card i {
        font-size: 20px;
        color: var(--text-muted);
        transition: all 0.2s ease;
        line-height: 1;
      }

      /* Tech Name Tooltip */
      .icon-card::after {
        content: attr(data-tech);
        position: absolute;
        bottom: 115%;
        left: 50%;
        transform: translateX(-50%) translateY(3px);
        background: oklch(18% 0.02 240);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: var(--text-primary);
        font-size: 0.65rem;
        font-weight: 600;
        padding: 3px 6px;
        border-radius: 4px;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        white-space: nowrap;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
        transition: all 0.2s ease;
        z-index: 10;
      }

      /* Position tooltips downward for the top row to prevent clipping */
      .icon-card:nth-child(-n+5)::after {
        bottom: auto;
        top: 115%;
        transform: translateX(-50%) translateY(-3px);
      }

      .icon-card:hover::after {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
      }

      .icon-card:hover {
        transform: translateY(-2px) scale(1.04);
        border-color: var(--hover-color);
        box-shadow: 0 0 12px var(--hover-glow);
        background: rgba(255, 255, 255, 0.03);
      }

      .icon-card:hover i {
        color: var(--hover-color);
        filter: drop-shadow(0 0 3px var(--hover-glow));
      }

      /* Mobile Switcher Tab header (Hidden on desktop) */
      .mobile-switcher-bar {
        display: none;
      }

      /* PROJECTS VIEW SECTION */
      .projects-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 24px;
        border-bottom: 1px solid var(--panel-border);
        flex-shrink: 0;
        width: 100%;
      }

      .breadcrumbs {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        color: var(--text-muted);
        font-weight: 500;
      }

      .breadcrumbs a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.2s ease;
        cursor: pointer;
      }

      .breadcrumbs a:hover {
        color: var(--accent-blue);
      }

      .breadcrumbs svg {
        width: 12px;
        height: 12px;
        fill: currentColor;
      }

      .breadcrumbs strong {
        color: var(--text-primary);
        font-weight: 600;
      }

      .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--text-secondary);
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--panel-border);
        padding: 6px 14px;
        border-radius: var(--radius-pill);
        cursor: pointer;
        transition: all 0.25s ease;
        flex-shrink: 0;
      }

      .btn-back:hover {
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.12);
        color: var(--text-primary);
        transform: translateX(-2px);
      }

      .btn-back svg {
        width: 14px;
        height: 14px;
        fill: currentColor;
      }

      /* Projects List body */
      .projects-body {
        flex-grow: 1;
        overflow: hidden;
        padding: 20px 24px 24px 24px;
        width: 100%;
        height: 100%;
      }

      /* Desktop Grid Layout (Fills height exactly, no scroll) */
      .projects-grid {
        display: grid;
        grid-template-columns: 1.15fr 1fr;
        gap: 16px;
        height: 100%;
        width: 100%;
      }

      .projects-col-right {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        grid-template-rows: repeat(2, 1fr);
        gap: 12px;
        height: 100%;
      }

      /* Project Card */
      .project-card {
        background: var(--panel-bg);
        border: 1px solid var(--panel-border);
        border-radius: var(--radius-lg);
        padding: 16px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
        transition: all 0.25s ease;
        text-decoration: none;
      }

      .project-card:hover {
        background: var(--panel-bg-hover);
        border-color: var(--panel-border-glow);
        box-shadow: 0 8px 24px rgba(99, 102, 241, 0.05);
        transform: translateY(-2px);
      }

      .project-card-top {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .project-kicker {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color: var(--accent-blue);
      }

      .project-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text-primary);
      }

      .project-desc {
        font-size: 0.8rem;
        line-height: 1.4;
        color: var(--text-secondary);
        font-weight: 300;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* Featured Project (nikao.tech) */
      .project-card.featured {
        height: 100%;
        background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.06), transparent 50%), var(--panel-bg);
        padding: 24px;
        gap: 20px;
        justify-content: space-between;
      }

      .project-card.featured .project-title {
        font-size: 1.5rem;
      }

      .project-card.featured .project-desc {
        -webkit-line-clamp: 4;
        font-size: 0.88rem;
      }

      .featured-visual {
        flex-grow: 1;
        border-radius: var(--radius-md);
        background: linear-gradient(135deg, rgba(255,255,255,0.01) 0%, rgba(255,255,255,0.005) 100%);
        border: 1px solid rgba(255,255,255,0.02);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
      }

      .featured-visual svg {
        width: 50px;
        height: 50px;
        filter: drop-shadow(0 0 8px rgba(99,102,241,0.2));
      }

      .project-link {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 0.76rem;
        font-weight: 600;
        color: var(--accent-blue);
        transition: all 0.2s ease;
        margin-top: auto;
        text-decoration: none;
      }

      .project-link:hover {
        color: var(--text-primary);
        gap: 6px;
      }

      .project-link svg {
        width: 12px;
        height: 12px;
        fill: currentColor;
      }

      .status-badge {
        font-size: 0.6rem;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.04);
        color: var(--text-muted);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 2px 6px;
        border-radius: 3px;
        text-transform: uppercase;
        align-self: flex-start;
      }

      /* Copy feedback toast */
      .toast {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%) translateY(60px);
        background: var(--bg-dark-soft);
        border: 1px solid var(--accent-blue);
        color: var(--text-primary);
        padding: 10px 20px;
        border-radius: var(--radius-pill);
        font-size: 0.8rem;
        font-weight: 600;
        box-shadow: var(--shadow-premium);
        z-index: 100;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.2), opacity 0.3s ease;
        opacity: 0;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .toast.is-visible {
        transform: translateX(-50%) translateY(0);
        opacity: 1;
      }

      .toast svg {
        width: 14px;
        height: 14px;
        fill: var(--accent-blue);
      }

      /* CSS slide/fade fallback transitions */
      .section-view {
        opacity: 0;
        transform: scale(0.985);
        transition: opacity 0.3s ease, transform 0.3s ease;
      }

      .section-view.is-visible {
        opacity: 1;
        transform: scale(1);
      }

      /* Mobile swiping carousel container (Hidden on desktop) */
      .mobile-carousel-container {
        display: none;
      }

      /* RESPONSIVE DESIGN - STRICT SCROLL-FREE VIEWPORT DESIGN */
      @media (max-width: 768px) {
        body {
          padding: 12px;
        }

        .shell {
          height: 100%;
          max-height: calc(100dvh - 24px);
        }

        .grid-layout {
